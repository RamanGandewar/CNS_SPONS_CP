{
  "title": "FrameTruth Overview",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "type": "stat",
      "title": "Analyses / min",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(frametruth_analyses_total[1m]) * 60",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "p95 Latency",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "frametruth_latency_p95_seconds",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "p99 Latency",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "frametruth_latency_p99_seconds",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Error Rate",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "rate(frametruth_errors_total[5m])",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Verdict Distribution",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 5 },
      "targets": [
        {
          "expr": "frametruth_verdict_total",
          "refId": "A",
          "legendFormat": "{{verdict}}"
        }
      ]
    }
  ]
}
